	<Button name="BulletinBoardListing" virtual="true" hidden="true">
		<Size>
			<AbsDimension x="500" y="20"/>
		</Size>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentBackground" setAllPoints="true">
					<Color r="1.0" g="1.0" b="1.0" a="1.0"/>
				</Texture>
			</Layer>
			<Layer level="ARTWORK">
				<FontString name="$parentSender" inherits="GameFontNormalSmall" text="Sender">
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parent">
							<Offset>
								<AbsDimension x="66" y="0"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
				<FontString name="$parentMessage" inherits="GameFontHighlightSmall" text="Message">
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parent">
							<Offset>
								<AbsDimension x="144" y="0"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>

				<Texture name="$parentRoleDPS" file="Interface\AddOns\VanillaEnhanced\Assets\BulletinBoard-Roles">
					<Size>
						<AbsDimension x="16" y="16"/>
					</Size>
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parent">
							<Offset>
								<AbsDimension x="4" y="0"/>
							</Offset>
						</Anchor>
					</Anchors>
					<TexCoords left="0.0" right="0.25" top="0.0" bottom="1.0"/>
				</Texture>

				<Texture name="$parentRoleHealer" file="Interface\AddOns\VanillaEnhanced\Assets\BulletinBoard-Roles">
					<Size>
						<AbsDimension x="16" y="16"/>
					</Size>
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parentRoleDPS" relativePoint="RIGHT">
							<Offset>
								<AbsDimension x="2" y="0"/>
							</Offset>
						</Anchor>
					</Anchors>
					<TexCoords left="0.25" right="0.5" top="0.0" bottom="1.0"/>
				</Texture>

				<Texture name="$parentRoleTank" file="Interface\AddOns\VanillaEnhanced\Assets\BulletinBoard-Roles">
					<Size>
						<AbsDimension x="16" y="16"/>
					</Size>
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parentRoleHealer" relativePoint="RIGHT">
							<Offset>
								<AbsDimension x="2" y="0"/>
							</Offset>
						</Anchor>
					</Anchors>
					<TexCoords left="0.5" right="0.75" top="0.0" bottom="1.0"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnClick>
				BulletinBoardListing_OnClick()
			</OnClick>
			<OnEnter>
				BulletinBoardListing_OnEnter()
			</OnEnter>
			<OnLeave>
				BulletinBoardListing_OnLeave()
			</OnLeave>
		</Scripts>
	</Button>

