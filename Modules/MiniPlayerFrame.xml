				</Anchors>
				<Frames>
					<Frame name="$parent1" inherits="MiniDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="-50" y="0" />
							</Anchor>
						</Anchors>
					</Frame>
					<Frame name="$parent2" inherits="MiniDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="-30" y="0" />
