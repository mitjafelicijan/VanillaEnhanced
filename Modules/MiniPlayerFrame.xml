							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="10" y="-20" />
							</Anchor>
						</Anchors>
					</Frame>
					<Frame name="$parent11" inherits="MiniDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="30" y="-20" />
							</Anchor>
						</Anchors>
					</Frame>
					<Frame name="$parent12" inherits="MiniDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="50" y="-20" />
							</Anchor>
						</Anchors>
