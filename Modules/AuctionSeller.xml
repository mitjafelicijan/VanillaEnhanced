<?xml version="1.0" encoding="UTF-8"?>
<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
	<Script file="AuctionSeller.lua" />

	<Frame name="AuctionSeller">
		<Scripts>
			<OnLoad>
				AuctionSeller_OnLoad()
			</OnLoad>
			<OnEvent>
				AuctionSeller_OnEvent()
			</OnEvent>
		</Scripts>
	</Frame>

	<Frame name="AuctionSellerBagItemButtonTemplate" virtual="true" hidden="false">
		<Size>
			<AbsDimension x="300" y="37"/>
		</Size>
	</Frame>

	<Frame name="AuctionSellerBagItemsFrame" frameStrata="HIGH" hidden="true">
		<Size x="185" y="355"/>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentLabel" inherits="GameFontHighlightSmall" text="Bag Items">
					<Anchors>
						<Anchor point="TOP" relativePoint="TOPLEFT" relativeTo="$parent">
							<Offset>
								<AbsDimension x="100" y="-4"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentButton1" inherits="AuctionSellerBagItemButtonTemplate" id="1">
				<Anchors>
					<Anchor point="TOP" relativePoint="TOPLEFT" relativeTo="$parent">
						<Offset>
							<AbsDimension x="100" y="-30"/>
						</Offset>
					</Anchor>
				</Anchors>
			</Button>
			<Button name="$parentButton2" inherits="AuctionSellerBagItemButtonTemplate" id="2">
				<Anchors>
					<Anchor point="TOP" relativePoint="TOPLEFT" relativeTo="$parent">
						<Offset>
							<AbsDimension x="100" y="-60"/>
						</Offset>
					</Anchor>
				</Anchors>
			</Button>
		</Frames>
	</Frame>

	<Frame name="AuctionSellerListingsFrame" frameStrata="HIGH" hidden="true">
		<Size x="610" y="250"/>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentLabel" inherits="GameFontHighlightSmall" text="Listings">
					<Anchors>
						<Anchor point="TOP" relativePoint="TOPLEFT" relativeTo="$parent">
							<Offset>
								<AbsDimension x="40" y="-20"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Frame>
</Ui>
