				</Layers>
			</Button>

			<StatusBar name="$parentHealthBar" frameLevel="2" hidden="false">
				<Size>
					<AbsDimension x="152" y="20"/>
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent">
						<Offset x="0" y="0"/>
					</Anchor>
				</Anchors>
				<BarTexture file="Interface\AddOns\VanillaEnhanced\Assets\RaidFrame-HealthFill" />
			</StatusBar>
		</Frames>

		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentNameText" inherits="GameFontHighlightSmall">
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parent">
							<Offset x="4" y="0" />
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>

		<Scripts>
			<OnLoad>
				NearbyEnemyFrame_OnLoad()
			</OnLoad>
			<OnClick>
				NearbyEnemyFrame_OnClick()
			</OnClick>
		</Scripts>
	</Button>

