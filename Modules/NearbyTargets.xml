		<Frames>
			<Frame frameStrata="BACKGROUND" frameLevel="1">
				<Size>
					<AbsDimension x="152" y="20"/>
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT"/>
				</Anchors>
				<Layers>
					<Layer level="BACKGROUND">
						<Texture setAllPoints="true" file="Interface\AddOns\VanillaEnhanced\Assets\Black8x8" />
					</Layer>
				</Layers>
			</Frame>

			<Button name="$parentInRange" hidden="true">
				<Size>
					<AbsDimension x="10" y="10"/>
				</Size>
				<Anchors>
					<Anchor point="RIGHT">
						<Offset x="-4" y="0"/>
					</Anchor>
				</Anchors>
				<Layers>
					<Layer level="ARTWORK">
						<Texture name="$parentTexture" file="Interface\AddOns\VanillaEnhanced\Assets\NearybyEnemies-InRange" setAllPoints="true"/>
