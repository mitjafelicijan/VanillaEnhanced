<?xml version="1.0" encoding="UTF-8"?>
<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
	<Script file="MiniPowerFrame.lua" />

	<Frame name="MiniPlayerDebuff" virtual="true">
		<Size>
			<AbsDimension x="22" y="22"/>
		</Size>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentTexture" file="Interface\Icons\Spell_Nature_ResistNature">
					<Size>
						<AbsDimension x="22" y="22"/>
					</Size>
					<Anchors>
						<Anchor point="CENTER">
							<Offset>
								<AbsDimension x="0" y="0"/>
							</Offset>
						</Anchor>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
	</Frame>

	<Frame name="MiniPowerFrame" parent="UIParent" frameStrata="BACKGROUND" toplevel="true" hidden="true">
		<Size x="120" y="40"/>
		<Anchors>
			<Anchor point="Center" relativePoint="Center" relativeTo="UIParent">
				<Offset x="0" y="-80" />
			</Anchor>
		</Anchors>

		<Frames>
			<!-- Player: Power Bar with Border -->
			<Frame frameLevel="2" name="$parentPower">
				<Size x="120" y="15"/>
				<Anchors>
					<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
						<Offset x="0" y="0" />
					</Anchor>
				</Anchors>
				<Frames>
					<StatusBar name="$parentStatusBar" inherits="TextStatusBar" frameLevel="1" alpha="0.9">
						<Size x="114" y="10"/>
						<Anchors>
							<Anchor point="CENTER" />
						</Anchors>
						<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
						<BarColor r="0.0" g="0.7" b="1.0" a="1.0"/>
					</StatusBar>
				</Frames>
				<Layers>
					<Layer level="BORDER">
						<Texture file="Interface\Tooltips\UI-StatusBar-Border" setAllPoints="true"/>
					</Layer>
				</Layers>
			</Frame>

			<!-- Player debuffs -->
			<Frame frameLevel="2" name="$parentPlayerDebuffs">
				<Size x="110" y="120"/>
				<Anchors>
					<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
						<Offset x="0" y="-22" />
					</Anchor>
				</Anchors>
				<Frames>
					<Frame name="$parent1" inherits="MiniPlayerDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="-42" y="0" />
							</Anchor>
						</Anchors>
					</Frame>
					<Frame name="$parent2" inherits="MiniPlayerDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="-14" y="0" />
							</Anchor>
						</Anchors>
					</Frame>
					<Frame name="$parent3" inherits="MiniPlayerDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="14" y="0" />
							</Anchor>
						</Anchors>
					</Frame>
					<Frame name="$parent4" inherits="MiniPlayerDebuff">
						<Anchors>
							<Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
								<Offset x="42" y="0" />
							</Anchor>
						</Anchors>
					</Frame>
				</Frames>
			</Frame>
		</Frames>

		<Scripts>
			<OnLoad>
				MiniPowerFrame_OnLoad()
			</OnLoad>
			<OnEvent>
				MiniPowerFrame_OnEvent()
			</OnEvent>
		</Scripts>
	</Frame>
</Ui>
